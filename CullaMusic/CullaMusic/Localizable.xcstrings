        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只能从 Culla 创建的播放列表中移出歌曲——歌曲将保留在这里。"
          }
        }
      }
    },
    "Songs you sort or dismiss show up here, newest first.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Titel, die du sortierst oder verwirfst, erscheinen hier – neueste zuerst."
          }
        },
