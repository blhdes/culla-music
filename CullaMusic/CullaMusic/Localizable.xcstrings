          "stringUnit": {
            "state": "translated",
            "value": "Las canciones que ordenes o descartes aparecerán aquí, las más recientes primero."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les titres que vous triez ou ignorez apparaissent ici, les plus récents d'abord."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I brani che ordini o scarti compaiono qui, i più recenti prima."
