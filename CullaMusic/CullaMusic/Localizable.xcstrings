    "Songs can only be moved out of playlists Culla created — they'll stay here.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Titel können nur aus von Culla erstellten Playlists verschoben werden – sie bleiben hier."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las canciones solo se pueden sacar de playlists creadas por Culla; se quedarán aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les titres ne peuvent être retirés que des playlists créées par Culla — ils resteront ici."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I brani possono essere spostati solo dalle playlist create da Culla: resteranno qui."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Cullaが作成したプレイリストからのみ移動できます。曲はここに残ります。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As músicas só podem ser movidas de playlists criadas pelo Culla — elas ficarão aqui."
          }
