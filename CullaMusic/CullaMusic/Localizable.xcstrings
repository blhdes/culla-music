    "Pick a playlist to sort songs from, or use your full library.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle eine Playlist, aus der du Titel sortierst, oder nimm deine ganze Mediathek."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige una playlist de la que ordenar canciones, o usa toda tu biblioteca."
