    "Everything stays on your device.\nCullaMusic never collects, tracks, or shares your data.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alles bleibt auf deinem Gerät.\nCullaMusic sammelt, verfolgt oder teilt deine Daten nie."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todo se queda en tu dispositivo.\nCullaMusic nunca recopila, rastrea ni comparte tus datos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout reste sur votre appareil.\nCullaMusic ne collecte, ne suit et ne partage jamais vos données."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutto resta sul tuo dispositivo.\nCullaMusic non raccoglie, traccia né condivide mai i tuoi dati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてはデバイス内に保存されます。\nCullaMusicがデータを収集・追跡・共有することはありません。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tudo fica no seu dispositivo.\nO CullaMusic nunca coleta, rastreia ou compartilha seus dados."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一切都保存在你的设备上。\nCullaMusic 绝不收集、跟踪或分享你的数据。"
          }
        }
      }
    },
