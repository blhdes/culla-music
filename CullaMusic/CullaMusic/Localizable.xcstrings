    "Access was denied. Open Settings to grant CullaMusic permission to your Apple Music library.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Zugriff wurde verweigert. Öffne die Einstellungen, um CullaMusic Zugriff auf deine Apple Music-Mediathek zu geben."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se denegó el acceso. Abre Ajustes para dar a CullaMusic permiso a tu biblioteca de Apple Music."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accès a été refusé. Ouvrez Réglages pour autoriser CullaMusic à accéder à votre bibliothèque Apple Music."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accesso è stato negato. Apri Impostazioni per dare a CullaMusic l'accesso alla tua libreria di Apple Music."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクセスが拒否されました。設定を開いて、CullaMusicにApple Musicライブラリへのアクセスを許可してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O acesso foi negado. Abra os Ajustes para dar ao CullaMusic permissão à sua biblioteca do Apple Music."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "访问被拒绝。请打开“设置”，允许 CullaMusic 访问你的 Apple Music 资料库。"
          }
        }
      }
    },
