    "Once you have playlists in your library, you can hide their tracks here.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sobald du Playlists in deiner Mediathek hast, kannst du ihre Titel hier ausblenden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando tengas playlists en tu biblioteca, podrás ocultar sus canciones aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quand vous aurez des playlists dans votre bibliothèque, vous pourrez masquer leurs titres ici."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando avrai delle playlist nella tua libreria, potrai nasconderne i brani qui."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ライブラリにプレイリストが追加されると、ここでその曲を非表示にできます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando você tiver playlists na sua biblioteca, poderá ocultar as músicas delas aqui."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "资料库中有播放列表后，可以在这里隐藏其中的歌曲。"
          }
        }
      }
    },
    "Once your library has artists, you can hide their tracks here.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sobald deine Mediathek Künstler enthält, kannst du ihre Titel hier ausblenden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando haya artistas en tu biblioteca, podrás ocultar sus canciones aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quand votre bibliothèque aura des artistes, vous pourrez masquer leurs titres ici."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando la tua libreria avrà degli artisti, potrai nasconderne i brani qui."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ライブラリにアーティストが追加されると、ここでその曲を非表示にできます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando sua biblioteca tiver artistas, você poderá ocultar as faixas deles aqui."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "资料库中有艺人后，可以在这里隐藏其歌曲。"
          }
        }
      }
    },
